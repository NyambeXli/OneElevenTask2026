{
  "$schema": "https://railway.app/v1.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish ./OneElevenTask_API/OneElevenTask_API.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/OneElevenTask_API.dll --urls=http://0.0.0.0:${PORT}",
    "restartPolicyType": "ON_FAILURE"
  }
}
